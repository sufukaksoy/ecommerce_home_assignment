FROM python:3.12-slim

WORKDIR /app

RUN apt-get update \
    && apt-get install -y --no-install-recommends socat \
    && rm -rf /var/lib/apt/lists/*

RUN pip install --no-cache-dir duckdb==1.2.1

COPY scripts/start_duckdb_ui_container.py /app/scripts/start_duckdb_ui_container.py

CMD ["python", "/app/scripts/start_duckdb_ui_container.py"]
